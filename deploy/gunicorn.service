[Unit]
Description=LYRA Gunicorn daemon
After=network.target

[Service]
User=lyra
Group=www-data
WorkingDirectory=/home/lyra/lyra
EnvironmentFile=/home/lyra/lyra/.env
ExecStart=/home/lyra/lyra/venv/bin/gunicorn \
    --workers 3 \
    --bind unix:/home/lyra/lyra/lyra.sock \
    lyra_platform.wsgi:application
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
