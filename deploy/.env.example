# Copy to /home/lyra/lyra/.env on the server and fill in values.
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=lyraaiqat.com,www.lyraaiqat.com,207.154.253.157
# After SSL is live, prefer https:// origins first:
DJANGO_CSRF_TRUSTED_ORIGINS=https://lyraaiqat.com,https://www.lyraaiqat.com,http://lyraaiqat.com,http://www.lyraaiqat.com

# Contact destination (shown on the website + receives form submissions).
DJANGO_CONTACT_EMAIL=info@lyraaiqat.com
DJANGO_DEFAULT_FROM_EMAIL=info@lyraaiqat.com

# ── SMTP (Bravenet / Bravehost mail) ──
DJANGO_EMAIL_HOST=mail.bravehost.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=info@lyraaiqat.com
DJANGO_EMAIL_HOST_PASSWORD=set-on-server-only
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False

# AI Agora referral webhook secret (share with Matrix TRC for enrollment callbacks).
DJANGO_AGORA_WEBHOOK_SECRET=generate-a-long-random-string
