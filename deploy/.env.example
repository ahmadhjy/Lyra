# Copy to /home/lyra/lyra/.env on the server and fill in values.
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=lyraaiqat.com,www.lyraaiqat.com,207.154.253.157
DJANGO_CSRF_TRUSTED_ORIGINS=http://lyraaiqat.com,http://www.lyraaiqat.com,https://lyraaiqat.com,https://www.lyraaiqat.com

# ── Contact form email (SMTP) ──
# Create the info@lyraaiqat.com mailbox in your hosting Email panel,
# then fill these with its SMTP credentials.
DJANGO_CONTACT_EMAIL=info@lyraaiqat.com
DJANGO_DEFAULT_FROM_EMAIL=info@lyraaiqat.com
DJANGO_EMAIL_HOST=mail.lyraaiqat.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=info@lyraaiqat.com
DJANGO_EMAIL_HOST_PASSWORD=your-mailbox-password
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
